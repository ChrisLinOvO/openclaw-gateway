{
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "bind": "lan",
    "mode": "local",
    "port": 10000
  },
  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOKS_TOKEN}",
    "path": "/hooks"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/stepfun/step-3.5-flash:free"
      },
      "memorySearch": {
        "enabled": false
      }
    }
  },
  "models": {
    "providers": {
      "openrouter": {
        "api": "openai-completions",
        "apiKey": "${OPENROUTER_API_KEY}",
        "baseUrl": "https://openrouter.ai/api/v1",
        "models": [
          {
            "id": "stepfun/step-3.5-flash:free",
            "name": "step-3.5-flash:free",
            "contextWindow": 16384,
            "input": ["text"]
          }
        ]
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "mode": "api_key",
        "provider": "openrouter"
      }
    }
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}"
    }
  },
  "env": {
    "GH_TOKEN": "${GH_TOKEN}",
    "GH_TOKEN_V2": "${GH_TOKEN_V2}"
  }
}
