{
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "bind": "lan",
    "mode": "local",
    "port": 18789
  },
  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOKS_TOKEN}",
    "path": "/hooks"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/minimax/minimax-m2.7:free"
      },
      "memorySearch": {
        "enabled": false
      }
    }
  },
  "models": {
    "providers": {
      "openrouter": {
        "api": "openai",
        "apiKey": "dummy-key-for-init",
        "baseUrl": "https://openrouter.ai/api/v1"
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "mode": "api_key",
        "provider": "openrouter"
      }
    }
  }
}
